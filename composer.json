{
    "name": "yezzmedia/laravel-ops-security",
    "description": "SSL, SSH, secret, and configuration security posture monitoring for Laravel applications.",
    "version": "0.2.1",
    "license": "proprietary",
    "type": "library",
    "require": {
        "php": "^8.4",
        "filament/filament": "^5.0",
        "illuminate/database": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-package-tools": "^1.93",
        "yezzmedia/laravel-foundation": "^0.2"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "suggest": {
        "spatie/laravel-activitylog": "Required for activity-log audit writer (^5.0)."
    },
    "autoload": {
        "psr-4": {
            "YezzMedia\\OpsSecurity\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "YezzMedia\\OpsSecurity\\OpsSecurityServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
